{
  "name": "movtools-client",
  "version": "1.3.10",
  "private": true,
  "description": "Movtools desktop client for collaborative production.",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev --outDir=out",
    "build": "electron-vite build --outDir=out",
    "prepare:icons": "node ./scripts/prepare-icons.mjs",
    "prepare:release": "node ./scripts/prepare-release.mjs",
    "prepare:runtime": "node ./scripts/prepare-runtime.mjs",
    "typecheck": "tsc --noEmit",
    "dist": "npm run dist:win",
    "dist:win": "npm run prepare:release && npm run build && npm run prepare:icons && npm run prepare:runtime && set \"CSC_IDENTITY_AUTO_DISCOVERY=false\" && (electron-builder --win nsis || electron-builder --prepackaged \"release/win-unpacked\" --win nsis)",
    "preview": "electron-vite preview --outDir=out"
  },
  "build": {
    "appId": "com.movtools.desktop",
    "productName": "萌粒制片管理系统",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/runtime",
        "to": "runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "win": {
      "executableName": "萌粒制片管理系统",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "萌粒制片管理系统",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "category": "public.app-category.video",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@microsoft/signalr": "^10.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "xlsx": "^0.18.5",
    "zod": "^4.1.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "typescript": "^5.9.2",
    "vite": "^5.4.21"
  }
}
